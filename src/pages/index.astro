---
import FlowLayout from '../layouts/FlowLayout.astro';
import { GAME_PORTFOLIO, SOCIAL_LINKS } from '../data/site';

const featuredGames = GAME_PORTFOLIO;
---

<FlowLayout
  title="Profile"
  description="Matthew Rushworth builds incremental games at Blindsided Games, with a systems-first approach, accessible UI focus, and a passion for long-tail progression design."
  path="/"
  ogImage="/img/logo.jpg"
>
  <div class="flow-sections">
    <section id="profile" class="flow-section" data-flow-section data-section-id="profile" data-reveal>
      <div class="section-shell single-column">
        <aside class="panel profile-aside" data-reveal style="--reveal-delay: 80ms">
          <div class="profile-aside-head">
            <img src="/img/logo.jpg" alt="Blindsided Games logo" width="108" height="108" />
            <div class="profile-aside-copy">
              <h2 class="profile-title">Blindsided Games</h2>
              <p>Independent studio founded in 2022, focused on long-tail systems and fast practical iteration.</p>
            </div>
          </div>
          <div class="tag-row">
            <span>Incremental design</span>
            <span>UI-first development</span>
            <span>Cross-platform</span>
          </div>
          <div class="social-inline" aria-label="Social channels">
            {SOCIAL_LINKS.map((social) => (
              <a href={social.href} target="_blank" rel="noopener noreferrer" aria-label={social.label}>
                <i class:list={[social.iconClass]} aria-hidden="true"></i>
              </a>
            ))}
          </div>
        </aside>

        <article class="panel hero-panel">
          <h2>My passion lies with incremental games.</h2>
          <p class="hero-copy">
            I am legally blind, so building traditional 2D or 3D action spaces can be limiting. I focus on dense,
            readable UI-driven game systems where clarity, progression, and momentum are the core experience.
          </p>
          <div class="button-row">
            <a class="btn btn-primary" href="#games">Explore Games</a>
            <button class="btn btn-secondary" type="button" data-open-contact>Contact Me</button>
          </div>
        </article>
      </div>
    </section>

    <section id="family" class="flow-section" data-flow-section data-section-id="family" data-reveal>
      <div class="section-shell single-column">
        <article class="panel narrative-panel">
          <h2>Family keeps this grounded.</h2>
          <p>
            I am building this studio around real life, not around nonstop crunch. I am a father first, and that
            perspective shapes the way I make games: calm pacing, practical structure, and systems that respect
            people’s time.
          </p>
          <p>
            This project is about enjoying the craft, shipping often, and building things I can be proud of over the
            long run.
          </p>
        </article>
      </div>
    </section>

    <section id="vision" class="flow-section" data-flow-section data-section-id="vision" data-reveal>
      <div class="section-shell split-column">
        <article class="panel narrative-panel">
          <h2>Living with Stargardt’s shapes how I build games.</h2>
          <p>
            I live with Stargardt visual impairment, which means detail-heavy scene reading can be difficult.
            That is why I focus on readable interfaces, strong contrast, and progression systems that feel clear
            without visual overload.
          </p>
          <p>
            This is not a limitation narrative. It is a design constraint I work with directly, and it has made my
            games more intentional, more structured, and easier to understand moment to moment.
          </p>
        </article>
        <article class="panel narrative-panel">
          <h3>What this changes in practice</h3>
          <ul>
            <li>Larger interaction targets and cleaner hierarchy in UI layouts</li>
            <li>System readability first, visual effects second</li>
            <li>Consistent feedback loops that can be parsed quickly</li>
            <li>Accessible presentation across desktop and mobile storefronts</li>
          </ul>
        </article>
      </div>
    </section>

    <section id="ai" class="flow-section" data-flow-section data-section-id="ai" data-reveal>
      <div class="section-shell single-column">
        <article class="panel narrative-panel">
          <h2>AI helps me ship faster and experiment further.</h2>
          <p>
            I use AI as a practical multiplier for research, drafting, and iteration loops. It does not replace game
            direction. It helps me move from idea to playable version quickly so I can focus on design choices and
            player experience.
          </p>
          <p>
            The goal is disciplined execution: better tools, clearer workflows, and more shipped improvements.
          </p>
        </article>
      </div>
    </section>

    <section id="games" class="flow-section" data-flow-section data-section-id="games" data-reveal>
      <div class="section-shell single-column">
        <div class="section-heading">
          <h2>Shipped Titles and Active Experiments</h2>
          <p>A live catalog of projects across browser, desktop, and mobile storefronts.</p>
        </div>

        <div class="games-grid">
          {featuredGames.map((game) => (
            <article class="panel game-showcase">
              <a
                class="game-showcase-media"
                href={game.primaryHref}
                target={game.primaryHref.startsWith('http') ? '_blank' : undefined}
                rel={game.primaryHref.startsWith('http') ? 'noopener noreferrer' : undefined}
                aria-label={`Open ${game.title}`}
              >
                <img src={game.image} alt={game.imageAlt} loading="lazy" decoding="async" />
              </a>
              <div class="game-showcase-copy">
                <h3>{game.title}</h3>
                <p>{game.description}</p>
                <div class="game-showcase-meta">
                  <div class="button-row compact">
                    {game.links.map((link) => (
                      <a
                        href={link.href}
                        target={link.external ? '_blank' : undefined}
                        rel={link.external ? 'noopener noreferrer' : undefined}
                        class="btn btn-secondary"
                      >
                        {link.label}
                      </a>
                    ))}
                  </div>
                  <p class="eyebrow subtle game-tag">{game.subtitle}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="support" class="flow-section" data-flow-section data-section-id="support" data-reveal>
      <div class="section-shell single-column">
        <article class="panel narrative-panel">
          <h2><i class="fa-brands fa-paypal" aria-hidden="true"></i> Support development</h2>
          <p>
            If you want to support ongoing development, updates, and future releases, you can contribute directly.
            Every bit of support helps me keep building.
          </p>
          <div class="button-row">
            <a class="btn btn-primary" href="https://paypal.me/vathreon" target="_blank" rel="noopener noreferrer">
              <span>Support via PayPal</span>
            </a>
          </div>
        </article>
      </div>
    </section>

    <section id="contact" class="flow-section" data-flow-section data-section-id="contact" data-reveal>
      <div class="section-shell single-column">
        <article class="panel narrative-panel contact-trigger-panel">
          <h2>Need to reach me directly?</h2>
          <p>
            Open the contact form for support, business, or collaboration messages. You can also use the Discord
            shortcut inside the panel.
          </p>
          <div class="button-row">
            <button class="btn btn-primary" type="button" data-open-contact>Open Contact Form</button>
          </div>
        </article>
      </div>
    </section>
  </div>
</FlowLayout>
