---
import { SOCIAL_LINKS } from '../data/site';

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-layout">
    <p>
      Blindsided Games &copy; {currentYear}
      <span aria-hidden="true"> / </span>
      <a href="/policy">Policy</a>
    </p>

    <div class="social-list" aria-label="Social links">
      {
        SOCIAL_LINKS.map((socialLink) => (
          <a class="social-pill" href={socialLink.href} target="_blank" rel="noopener noreferrer" aria-label={socialLink.label}>
            <i class:list={[socialLink.iconClass]} aria-hidden="true"></i>
            <span>{socialLink.label}</span>
          </a>
        ))
      }
    </div>
  </div>
</footer>
